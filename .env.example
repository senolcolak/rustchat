# rustchat environment configuration
# Copy this file to .env and adjust values as needed.

# Core server
RUSTCHAT_ENVIRONMENT=development
RUSTCHAT_SERVER_HOST=0.0.0.0
RUSTCHAT_SERVER_PORT=3000
RUSTCHAT_SITE_URL=http://localhost:8080
RUSTCHAT_LOG_LEVEL=info
RUSTCHAT_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# Auth and secrets (required)
RUSTCHAT_JWT_SECRET=replace-with-a-long-random-secret
RUSTCHAT_JWT_EXPIRY_HOURS=24
RUSTCHAT_ENCRYPTION_KEY=replace-with-a-long-random-32-byte-key

# Storage (RustFS/S3)
RUSTCHAT_S3_ENDPOINT=http://localhost:9000
RUSTCHAT_S3_PUBLIC_ENDPOINT=http://localhost:9000
RUSTCHAT_S3_BUCKET=rustchat-uploads
RUSTCHAT_S3_ACCESS_KEY=minioadmin
RUSTCHAT_S3_SECRET_KEY=minioadmin
RUSTCHAT_S3_REGION=us-east-1

# Data stores
RUSTCHAT_DATABASE_URL=postgres://rustchat:rustchat@localhost:5432/rustchat
RUSTCHAT_REDIS_URL=redis://localhost:6379

# Optional admin bootstrap
RUSTCHAT_ADMIN_USER=admin@rustchat.local
RUSTCHAT_ADMIN_PASSWORD=

# Calls plugin runtime configuration (used by docker-compose backend service)
RUSTCHAT_CALLS_ENABLED=true
RUSTCHAT_CALLS_UDP_PORT=8443
RUSTCHAT_CALLS_TCP_PORT=8443
RUSTCHAT_CALLS_ICE_HOST_OVERRIDE=

# Optional advanced calls defaults (read from backend config)
RUSTCHAT_CALLS_STUN_SERVERS=stun:stun.l.google.com:19302
RUSTCHAT_CALLS_TURN_TTL_MINUTES=1440

# TURN server compatibility variables (used by docker-compose backend service)
TURN_SERVER_ENABLED=false
TURN_SERVER_URL=turn:turn.kubedo.io:3478
TURN_SERVER_USERNAME=replace-with-turn-username
TURN_SERVER_CREDENTIAL=replace-with-turn-password

# Push Notification Proxy (Sidecar)
# For Android push notifications (FCM)
FIREBASE_PROJECT_ID=replace-with-your-project-id
FIREBASE_KEY_PATH=./secrets/firebase-key.json

# For iOS VoIP push notifications (APNS)
# Generate VoIP certificate at: https://developer.apple.com/account/resources/certificates/list
APNS_CERT_PATH=./secrets/voip-cert.pem
APNS_KEY_PATH=./secrets/voip-key.pem
APNS_CERT_PASSWORD=
APNS_BUNDLE_ID=com.rustchat.app
APNS_USE_PRODUCTION=false

# Push proxy connection
RUSTCHAT_PUSH_PROXY_URL=http://localhost:3000
