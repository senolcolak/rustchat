# Base image with all dependencies pre-compiled
# Build and push this manually when Cargo.toml changes
FROM rust:1.93-alpine AS builder

RUN apk add --no-cache musl-dev pkgconfig openssl-dev

WORKDIR /app

# Copy and build dependencies
COPY Cargo.toml Cargo.lock ./
RUN mkdir src && echo 'fn main() {}' > src/main.rs && \
    cargo build --release && \
    rm -rf src

# This image now has all dependencies compiled
# Use as: FROM rustchat-backend:base AS builder
