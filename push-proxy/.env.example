# RustChat Push Proxy Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Firebase Cloud Messaging (Android)
# =============================================================================

# Your Firebase Project ID (found in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-project-id

# Path to your Firebase service account JSON key file
# Generate this in Firebase Console → Project Settings → Service Accounts
FIREBASE_KEY_PATH=./secrets/firebase-key.json

# =============================================================================
# Apple Push Notification Service (iOS VoIP)
# =============================================================================

# Path to your APNS Auth Key (.p8 file)
# Generate this in Apple Developer Portal → Keys → Add Key
# Download the .p8 file and save it to secrets/
APNS_KEY_PATH=./secrets/AuthKey_KEYID.p8

# Key ID (found in Apple Developer Portal next to your key)
APNS_KEY_ID=YOUR_KEY_ID

# Team ID (found in Apple Developer Portal → Membership)
APNS_TEAM_ID=YOUR_TEAM_ID

# Your iOS app bundle identifier (e.g., com.rustchat.app)
APNS_BUNDLE_ID=com.rustchat.app

# Use production APNS servers?
# Set to 'true' for production, 'false' for development/sandbox
APNS_USE_PRODUCTION=false

# =============================================================================
# Server Configuration
# =============================================================================

# Port to listen on (default: 3000)
RUSTCHAT_PUSH_PORT=3000

# Logging level (error, warn, info, debug, trace)
RUST_LOG=push_proxy=info

# =============================================================================
# Notes
# =============================================================================

# For Android-only support:
# - Only FIREBASE_PROJECT_ID and FIREBASE_KEY_PATH are required
# - APNS configuration can be omitted

# For iOS-only support:
# - Only APNS_* variables are required
# - Firebase configuration can be omitted

# For full Android + iOS support:
# - All variables should be configured

# Certificate files should be placed in the secrets/ directory
# and have restrictive permissions (chmod 600)
